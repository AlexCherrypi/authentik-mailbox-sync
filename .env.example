# Secrets — generate with: python -c 'import secrets; print(secrets.token_hex(32))'
SYNC_WEBHOOK_SECRET=
SYNC_ADMIN_TOKEN=

# Mailcow
# Internal hostname or external URL that resolves to nginx-mailcow.
MAILCOW_API=http://nginx-mailcow
# Read-write API key from Mailcow Admin UI → Access → API
MAILCOW_API_KEY=

# Mailcow MariaDB (needed for SOGo delegation writes — sogo-tool is broken in
# Mailcow's container layout, see mailcow/mailcow-dockerized#6355).
MAILCOW_DB_HOST=mysql-mailcow
MAILCOW_DB_NAME=mailcow
MAILCOW_DB_USER=mailcow
MAILCOW_DB_PASSWORD=

# Authentik (for the periodic sweep that reconciles every Authentik-known user)
AUTHENTIK_API_URL=
AUTHENTIK_API_TOKEN=

# Service config
# All mailboxes outside this domain are treated as user-owned and left untouched.
OUR_DOMAIN=example.com
# Where the SQLite state DB lives inside the container — bind-mount this from the host.
STATE_DB_PATH=/var/lib/sync/state.db
# Container names for `docker exec` targets (must match your Mailcow/Nextcloud deployment).
DOVECOT_CONTAINER=mailcow-dovecot-mailcow-1
MEMCACHED_CONTAINER=mailcow-memcached-mailcow-1
NEXTCLOUD_CONTAINER=nextcloud
LOG_LEVEL=info
